<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Happy Birthday ❤️</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

body{
    font-family: Arial, sans-serif;
    background: linear-gradient(135deg, #ff9a9e, #fad0c4);
    text-align:center;
    color:white;
    min-height:100vh;
    padding:20px;
}

h1{
    margin-top:20px;
    font-size:42px;
}

.message{
    margin:15px auto 25px;
    max-width:600px;
    font-size:18px;
    line-height:1.5;
}

.music-btn{
    padding:12px 24px;
    border:none;
    border-radius:25px;
    font-size:16px;
    cursor:pointer;
    margin-bottom:25px;
}

.slideshow-container{
    width:90%;
    max-width:420px;
    margin:auto;
    border-radius:20px;
    overflow:hidden;
    box-shadow:0 10px 30px rgba(0,0,0,0.3);
    background:white;
}

.slide{
    display:none;
}

.slide img{
    width:100%;
    height:500px;
    object-fit:cover;
}

.caption{
    background:rgba(0,0,0,0.6);
    color:white;
    padding:12px;
    font-size:18px;
}

.footer{
    margin-top:25px;
    font-size:16px;
}
</style>
</head>

<body>

<h1>🎂 Happy Birthday 🎉</h1>

<div class="message">
    Wishing you happiness, good health, success, and lots of love today and always. ❤️
</div>

<audio id="bgMusic" loop>
    <source src="freesound_community-happy-birthday-to-you-made-by-me-100631.mp3" type="audio/mpeg">
</audio>

<button class="music-btn" onclick="document.getElementById('bgMusic').play()">
    🎶 Play Music
</button>

<div class="slideshow-container">

    <div class="slide">
        <img src="1774385284659.jpg" alt="Photo 1">
        <div class="caption">💖 Happy Birthday!</div>
    </div>

    <div class="slide">
        <img src="IMG-20251216-WA0025.jpg" alt="Photo 2">
        <div class="caption">💕 Beautiful Memories</div>
    </div>

    <div class="slide">
        <img src="IMG_20260223_123031.jpg" alt="Photo 3">
        <div class="caption">🥰 Special Moments</div>
    </div>

    <div class="slide">
        <img src="IMG_20260223_140215.png" alt="Photo 4">
        <div class="caption">❤️ Forever Grateful</div>
    </div>

    <div class="slide">
        <img src="IMG_20260224_223406.jpg" alt="Photo 5">
        <div class="caption">🌹 You Mean So Much</div>
    </div>

    <div class="slide">
        <img src="IMG_20260502_234449_135.jpg" alt="Photo 6">
        <div class="caption">🎉 Have The Best Birthday Ever!</div>
    </div>

</div>

<div class="footer">
    ❤️ Made with love ❤️
</div>

<script>
let slideIndex = 0;
showSlides();

function showSlides() {
    const slides = document.getElementsByClassName("slide");

    for (let i = 0; i < slides.length; i++) {
        slides[i].style.display = "none";
    }

    slideIndex++;

    if (slideIndex > slides.length) {
        slideIndex = 1;
    }

    slides[slideIndex - 1].style.display = "block";

    setTimeout(showSlides, 3000);
}
</script>

</body>
</html>
