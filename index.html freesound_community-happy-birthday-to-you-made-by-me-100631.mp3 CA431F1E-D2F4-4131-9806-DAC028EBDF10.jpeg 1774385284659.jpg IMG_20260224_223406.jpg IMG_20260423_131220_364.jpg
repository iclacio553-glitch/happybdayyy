<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Happy Birthday ❤️</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

body{
    font-family: Arial, sans-serif;
    background: linear-gradient(135deg, #ff9a9e, #fad0c4);
    color:white;
    text-align:center;
    min-height:100vh;
    padding:20px;
}

h1{
    margin-top:20px;
    font-size:42px;
}

.message{
    margin-top:10px;
    font-size:18px;
    padding:0 15px;
}

.slideshow-container{
    max-width:400px;
    margin:30px auto;
    position:relative;
    overflow:hidden;
    border-radius:20px;
    box-shadow:0 10px 30px rgba(0,0,0,0.3);
    background:white;
}

.slide{
    display:none;
}

.slide img{
    width:100%;
    height:500px;
    object-fit:cover;
}

.caption{
    background:rgba(0,0,0,0.6);
    padding:12px;
    font-size:18px;
}

.music-btn{
    margin-top:20px;
    padding:12px 24px;
    border:none;
    border-radius:25px;
    font-size:16px;
    cursor:pointer;
}

.footer{
    margin-top:25px;
    font-size:16px;
    padding-bottom:20px;
}
</style>
</head>

<body>

<h1>🎂 Happy Birthday 🎉</h1>

<div class="message">
    Wishing you endless happiness, good health, success, and lots of love today and always. ❤️
</div>

<!-- MUSIC -->
<audio id="bgMusic" loop>
    <source src="freesound_community-happy-birthday-to-you-made-by-me-100631.mp3" type="audio/mpeg">
</audio>

<button class="music-btn" onclick="document.getElementById('bgMusic').play()">
    🎶 Play Music
</button>

<!-- SLIDESHOW -->
<div class="slideshow-container">

    <div class="slide">
        <img src="CA431F1E-D2F4-4131-9806-DAC028EBDF10.jpeg" alt="Photo 1">
        <div class="caption">💖 Happy Birthday!</div>
    </div>

    <div class="slide">
        <img src="1774385284659.jpg" alt="Photo 2">
        <div class="caption">💕 Thank You For Being You</div>
    </div>

    <div class="slide">
        <img src="IMG_20260224_223406.jpg" alt="Photo 3">
        <div class="caption">🥰 Every Moment With You Is Special</div>
    </div>

    <div class="slide">
        <img src="IMG_20260423_131220_364.jpg" alt="Photo 4">
        <div class="caption">🎂 Wishing You The Best Birthday Ever!</div>
    </div>

</div>

<div class="footer">
    ❤️ Made with love ❤️
</div>

<script>
let slideIndex = 0;
showSlides();

function showSlides() {
    let slides = document.getElementsByClassName("slide");

    for (let i = 0; i < slides.length; i++) {
        slides[i].style.display = "none";
    }

    slideIndex++;

    if (slideIndex > slides.length) {
        slideIndex = 1;
    }

    slides[slideIndex - 1].style.display = "block";

    setTimeout(showSlides, 3000);
}
</script>

</body>
</html>
